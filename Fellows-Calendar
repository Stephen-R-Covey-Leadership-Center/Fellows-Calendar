<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Covey Fellows Calendar</title>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:    #1B2D4F;
      --navy-mid:#254070;
      --gold:    #B8892A;
      --gold-lt: #F0D98E;
      --white:   #ffffff;
      --off-white:#F6F7F9;
      --gray:    #5A6477;
      --gray-lt: #D1D5DC;
      --border:  #DDE1E9;
      --shadow:  0 4px 20px rgba(27,45,79,0.10);
      --shadow-lg: 0 8px 36px rgba(27,45,79,0.16);
    }

    body {
      font-family: 'Source Sans 3', sans-serif;
      background-color: var(--off-white);
      color: var(--navy);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0 0 60px;
    }

    /* ── HEADER: logo on cream with gold rule ── */
    .site-header {
      width: 100%;
      background: #FDFCF9;
      border-bottom: 3px solid var(--gold);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 36px 24px 28px;
      gap: 14px;
    }

    .site-header img {
      max-width: 380px;
      width: 80%;
      height: auto;
      display: block;
    }

    .fellows-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .fellows-badge::before,
    .fellows-badge::after {
      content: '';
      display: block;
      width: 28px;
      height: 1.5px;
      background: var(--gold);
      border-radius: 1px;
    }

    /* ── MAIN CONTENT ── */
    .main-content {
      width: 100%;
      max-width: 900px;
      padding: 44px 20px 0;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    h1 {
      font-family: 'Libre Baskerville', serif;
      font-size: clamp(1.5rem, 4vw, 2.1rem);
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 10px;
      text-align: center;
      line-height: 1.2;
    }

    .divider {
      width: 48px;
      height: 3px;
      background: var(--gold);
      margin: 0 auto 16px;
      border-radius: 2px;
    }

    .subtitle {
      font-size: 0.97rem;
      color: var(--gray);
      font-weight: 300;
      margin-bottom: 40px;
      text-align: center;
      max-width: 520px;
      line-height: 1.6;
    }

    /* ── CARDS ── */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 16px;
      width: 100%;
      max-width: 900px;
      margin-bottom: 28px;
    }

    .cal-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-top: 3px solid var(--navy);
      border-radius: 8px;
      padding: 24px 20px 20px;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
      box-shadow: var(--shadow);
      transition: box-shadow 0.2s, transform 0.2s, border-top-color 0.2s;
    }

    .cal-card:hover {
      box-shadow: var(--shadow-lg);
      transform: translateY(-2px);
      border-top-color: var(--gold);
    }

    .cal-icon {
      width: 42px;
      height: 42px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .cal-icon svg { width: 42px; height: 42px; }

    .cal-label {
      font-family: 'Libre Baskerville', serif;
      font-size: 0.98rem;
      font-weight: 700;
      color: var(--navy);
      line-height: 1.2;
    }

    .cal-desc {
      font-size: 0.82rem;
      color: var(--gray);
      font-weight: 300;
      line-height: 1.5;
      flex: 1;
    }

    .cal-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 18px;
      border-radius: 5px;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: opacity 0.15s, transform 0.15s, background 0.15s;
      color: var(--white);
      width: 100%;
      justify-content: center;
      letter-spacing: 0.02em;
    }

    .cal-btn:hover { opacity: 0.88; transform: scale(0.98); }

    .btn-google  { background: #1A73E8; }
    .btn-apple   { background: var(--navy); }
    .btn-outlook { background: #0078D4; }

    /* ── INSTRUCTIONS PANEL ── */
    .instructions-wrap {
      width: 100%;
      max-width: 900px;
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.4s ease;
    }
    .instructions-wrap.open { max-height: 900px; }

    .instructions-panel {
      background: var(--white);
      border: 1px solid var(--border);
      border-left: 4px solid var(--navy);
      border-radius: 8px;
      padding: 28px 28px 24px;
      box-shadow: var(--shadow);
      margin-bottom: 16px;
    }

    .instructions-panel h3 {
      font-family: 'Libre Baskerville', serif;
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 16px;
      color: var(--navy);
    }

    .tab-row {
      display: flex;
      gap: 0;
      margin-bottom: 20px;
      border-bottom: 2px solid var(--border);
      flex-wrap: wrap;
    }

    .tab-btn {
      background: none;
      border: none;
      padding: 8px 16px;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.83rem;
      font-weight: 600;
      color: var(--gray);
      cursor: pointer;
      border-bottom: 3px solid transparent;
      margin-bottom: -2px;
      transition: color 0.15s, border-color 0.15s;
      letter-spacing: 0.01em;
    }

    .tab-btn.active { color: var(--navy); border-bottom-color: var(--gold); }

    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    ol {
      padding-left: 20px;
      font-size: 0.9rem;
      line-height: 1.8;
      color: #374151;
    }

    ol li { margin-bottom: 4px; }

    .url-box {
      display: flex;
      align-items: stretch;
      margin: 12px 0 8px;
      border: 1.5px solid var(--border);
      border-radius: 5px;
      overflow: hidden;
    }

    .url-box code {
      flex: 1;
      background: var(--off-white);
      padding: 10px 12px;
      font-family: 'Courier New', monospace;
      font-size: 0.75rem;
      color: var(--navy);
      word-break: break-all;
      display: block;
      border: none;
    }

    .copy-btn {
      background: var(--navy);
      color: var(--white);
      border: none;
      padding: 0 16px;
      font-size: 0.8rem;
      font-family: 'Source Sans 3', sans-serif;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.15s;
    }

    .copy-btn:hover { background: var(--gold); }
    .copy-btn.copied { background: #2E7D32; }

    .note-box {
      background: #FEF9EC;
      border: 1px solid var(--gold-lt);
      border-left: 3px solid var(--gold);
      border-radius: 5px;
      padding: 10px 14px;
      font-size: 0.82rem;
      color: #5C4A1A;
      margin-top: 14px;
      line-height: 1.5;
    }

    footer {
      margin-top: 48px;
      font-size: 0.75rem;
      color: var(--gray-lt);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    @media (max-width: 520px) {
      .card-grid { grid-template-columns: 1fr; }
      .instructions-panel { padding: 20px 16px; }
      .tab-btn { padding: 8px 10px; font-size: 0.78rem; }
      .site-header img { max-width: 280px; }
    }
  </style>
</head>
<body>

  <!-- HEADER: centered logo on cream with gold bottom rule -->
  <header class="site-header">
    <img src="data:image/png;base64," alt="The Stephen R. Covey Leadership Center" />
    <div class="fellows-badge">Covey Fellows Calendar</div>
  </header>

  <div class="main-content">
    <h1>Fellows Events Calendar</h1>
    <div class="divider"></div>
    <p class="subtitle">Subscribe to stay up-to-date with all Covey Fellows events. Choose your calendar app below for a live, auto-updating subscription.</p>

    <div class="card-grid">

      <!-- Google Calendar -->
      <div class="cal-card">
        <div class="cal-icon">
          <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="8" width="40" height="36" rx="3" fill="#fff" stroke="#E0E0E0" stroke-width="1"/>
            <rect x="4" y="8" width="40" height="8" rx="3" fill="#1A73E8"/>
            <rect x="4" y="12" width="40" height="4" fill="#1A73E8"/>
            <path d="M32 4v8M16 4v8" stroke="#757575" stroke-width="3" stroke-linecap="round"/>
            <line x1="4" y1="26" x2="44" y2="26" stroke="#E0E0E0" stroke-width="0.8"/>
            <line x1="4" y1="35" x2="44" y2="35" stroke="#E0E0E0" stroke-width="0.8"/>
            <line x1="18" y1="20" x2="18" y2="44" stroke="#E0E0E0" stroke-width="0.8"/>
            <line x1="31" y1="20" x2="31" y2="44" stroke="#E0E0E0" stroke-width="0.8"/>
            <rect x="31" y="26" width="13" height="9" fill="#1A73E8" opacity="0.15"/>
            <text x="37" y="33.5" text-anchor="middle" font-family="Arial,sans-serif" font-size="6.5" font-weight="700" fill="#1A73E8">31</text>
            <text x="11" y="25" text-anchor="middle" font-family="Arial,sans-serif" font-size="5.5" fill="#757575">1</text>
            <text x="24.5" y="25" text-anchor="middle" font-family="Arial,sans-serif" font-size="5.5" fill="#757575">2</text>
            <text x="11" y="34" text-anchor="middle" font-family="Arial,sans-serif" font-size="5.5" fill="#757575">8</text>
            <text x="24.5" y="34" text-anchor="middle" font-family="Arial,sans-serif" font-size="5.5" fill="#757575">9</text>
            <text x="11" y="43" text-anchor="middle" font-family="Arial,sans-serif" font-size="5.5" fill="#757575">15</text>
            <text x="24.5" y="43" text-anchor="middle" font-family="Arial,sans-serif" font-size="5.5" fill="#757575">16</text>
            <text x="37" y="43" text-anchor="middle" font-family="Arial,sans-serif" font-size="5.5" fill="#757575">23</text>
          </svg>
        </div>
        <div class="cal-label">Google Calendar</div>
        <p class="cal-desc">One click to subscribe. Events stay in sync automatically.</p>
        <a href="https://calendar.google.com/calendar/u/0/r?cid=52e8e3ab637b4bd9cbd0441181013e401bfb62428555e949e059879578b5cdb7@group.calendar.google.com" target="_blank" rel="noopener noreferrer" class="cal-btn btn-google">
          Subscribe →
        </a>
      </div>

      <!-- Apple Calendar Mac -->
      <div class="cal-card">
        <div class="cal-icon">
          <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="8" width="40" height="36" rx="4" fill="#fff" stroke="#D1D5DC" stroke-width="1"/>
            <rect x="4" y="8" width="40" height="12" rx="4" fill="#E53935"/>
            <rect x="4" y="16" width="40" height="4" fill="#E53935"/>
            <path d="M16 4v8M32 4v8" stroke="#9E9E9E" stroke-width="2.5" stroke-linecap="round"/>
            <text x="24" y="15" text-anchor="middle" font-family="Arial,sans-serif" font-size="6" font-weight="700" fill="white" letter-spacing="1">MON</text>
            <text x="24" y="36" text-anchor="middle" font-family="Arial,sans-serif" font-size="18" font-weight="700" fill="#1B2D4F">12</text>
          </svg>
        </div>
        <div class="cal-label">Apple Calendar (Mac)</div>
        <p class="cal-desc">Subscribe via Calendar.app for a live connection that auto-updates.</p>
        <button class="cal-btn btn-apple" onclick="togglePanel('applePanel')">
          View Instructions →
        </button>
      </div>

      <!-- Apple Calendar iPhone/iPad -->
      <div class="cal-card">
        <div class="cal-icon">
          <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <rect x="12" y="2" width="24" height="44" rx="4" fill="#fff" stroke="#D1D5DC" stroke-width="1.5"/>
            <rect x="12" y="2" width="24" height="14" rx="4" fill="#E53935"/>
            <rect x="12" y="10" width="24" height="6" fill="#E53935"/>
            <circle cx="24" cy="42" r="2.2" fill="#9E9E9E"/>
            <text x="24" y="13.5" text-anchor="middle" font-family="Arial,sans-serif" font-size="5" font-weight="700" fill="white" letter-spacing="0.5">MON</text>
            <text x="24" y="31" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" font-weight="700" fill="#1B2D4F">12</text>
          </svg>
        </div>
        <div class="cal-label">Apple Calendar (iPhone / iPad)</div>
        <p class="cal-desc">Tap in <strong>Safari</strong> to subscribe. Opens Calendar automatically.</p>
        <a href="webcal://calendar.google.com/calendar/ical/52e8e3ab637b4bd9cbd0441181013e401bfb62428555e949e059879578b5cdb7@group.calendar.google.com/public/basic.ics" class="cal-btn btn-apple">
          Subscribe →
        </a>
      </div>

      <!-- Outlook -->
      <div class="cal-card">
        <div class="cal-icon">
          <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <rect x="2" y="6" width="28" height="36" rx="3" fill="#0078D4"/>
            <rect x="6" y="14" width="20" height="14" rx="1.5" fill="white" opacity="0.92"/>
            <polyline points="6,14 16,22 26,14" fill="none" stroke="#0078D4" stroke-width="1.8" stroke-linejoin="round"/>
            <text x="16" y="35" text-anchor="middle" font-family="Arial,sans-serif" font-size="10" font-weight="900" fill="white">O</text>
            <rect x="22" y="18" width="24" height="26" rx="2" fill="white" stroke="#E0E0E0" stroke-width="1"/>
            <rect x="22" y="18" width="24" height="8" rx="2" fill="#0078D4"/>
            <rect x="22" y="22" width="24" height="4" fill="#0078D4"/>
            <text x="34" y="25" text-anchor="middle" font-family="Arial,sans-serif" font-size="4.5" font-weight="700" fill="white" letter-spacing="0.5">OCT</text>
            <text x="27" y="33" text-anchor="middle" font-family="Arial,sans-serif" font-size="4" fill="#757575">5</text>
            <text x="34" y="33" text-anchor="middle" font-family="Arial,sans-serif" font-size="4" fill="#757575">6</text>
            <text x="41" y="33" text-anchor="middle" font-family="Arial,sans-serif" font-size="4" fill="#757575">7</text>
            <text x="27" y="39" text-anchor="middle" font-family="Arial,sans-serif" font-size="4" fill="#757575">12</text>
            <rect x="29.5" y="34.5" width="9" height="6" rx="1" fill="#0078D4" opacity="0.12"/>
            <text x="34" y="39" text-anchor="middle" font-family="Arial,sans-serif" font-size="4" fill="#0078D4" font-weight="700">13</text>
            <text x="41" y="39" text-anchor="middle" font-family="Arial,sans-serif" font-size="4" fill="#757575">14</text>
          </svg>
        </div>
        <div class="cal-label">Microsoft Outlook</div>
        <p class="cal-desc">Subscribe via Outlook desktop or Outlook on the web for live sync.</p>
        <button class="cal-btn btn-outlook" onclick="togglePanel('outlookPanel')">
          View Instructions →
        </button>
      </div>

    </div><!-- end .card-grid -->

    <!-- Apple instructions panel -->
    <div class="instructions-wrap" id="applePanel">
      <div class="instructions-panel">
        <h3>How to subscribe in Apple Calendar (Mac)</h3>
        <div class="tab-row">
          <button class="tab-btn active" onclick="switchTab(this,'tab-apple-mac')">Mac (Calendar App)</button>
          <button class="tab-btn" onclick="switchTab(this,'tab-apple-ios')">iPhone / iPad</button>
        </div>
        <div class="tab-panel active" id="tab-apple-mac">
          <ol>
            <li>Open the <strong>Calendar</strong> app on your Mac (not a browser).</li>
            <li>In the menu bar, click <strong>File → New Calendar Subscription…</strong></li>
            <li>Paste the link below into the calendar URL field:</li>
          </ol>
          <div class="url-box">
            <code id="icsLink-apple-mac">webcal://calendar.google.com/calendar/ical/52e8e3ab637b4bd9cbd0441181013e401bfb62428555e949e059879578b5cdb7@group.calendar.google.com/public/basic.ics</code>
            <button class="copy-btn" onclick="copyLink('icsLink-apple-mac', this)">Copy</button>
          </div>
          <ol start="4">
            <li>Click <strong>Subscribe</strong>.</li>
            <li>Give it a name (e.g. <em>Covey Fellows Events</em>), set <strong>Auto-refresh</strong> to <em>Every day</em>, and click <strong>OK</strong>.</li>
          </ol>
          <div class="note-box">
            📌 This works in any browser on Mac because you paste directly into Calendar.app — no browser protocol handling needed.
          </div>
        </div>
        <div class="tab-panel" id="tab-apple-ios">
          <ol>
            <li>Open this page in <strong>Safari</strong> on your iPhone or iPad.</li>
            <li>Tap the <strong>Subscribe →</strong> button on the Apple Calendar (iPhone/iPad) card.</li>
            <li>A prompt will appear asking if you want to subscribe — tap <strong>Subscribe</strong>.</li>
            <li>Review the settings and tap <strong>Done</strong>.</li>
          </ol>
          <div class="note-box">
            📌 <strong>Events not updating?</strong> iOS can take up to an hour to sync. To force a refresh: go to <strong>Settings → Calendar → Accounts</strong>, tap the subscribed calendar, and toggle it off and back on.
          </div>
        </div>
      </div>
    </div>

    <!-- Outlook instructions panel -->
    <div class="instructions-wrap" id="outlookPanel">
      <div class="instructions-panel">
        <h3>How to subscribe in Microsoft Outlook</h3>
        <div class="tab-row">
          <button class="tab-btn active" onclick="switchTab(this,'tab-web')">Outlook on the Web</button>
          <button class="tab-btn" onclick="switchTab(this,'tab-desktop')">Outlook Desktop (365)</button>
          <button class="tab-btn" onclick="switchTab(this,'tab-new')">New Outlook (2023+)</button>
        </div>
        <div class="tab-panel active" id="tab-web">
          <ol>
            <li>Go to <strong>outlook.office.com</strong> or <strong>outlook.com</strong> and sign in.</li>
            <li>Click the <strong>Calendar</strong> icon in the left sidebar.</li>
            <li>Click <strong>Add calendar</strong> (top-left, next to "My calendars").</li>
            <li>Select <strong>"Subscribe from web"</strong>.</li>
            <li>Paste the link below into the URL field:</li>
          </ol>
          <div class="url-box">
            <code id="icsLink-web">https://calendar.google.com/calendar/ical/52e8e3ab637b4bd9cbd0441181013e401bfb62428555e949e059879578b5cdb7%40group.calendar.google.com/public/basic.ics</code>
            <button class="copy-btn" onclick="copyLink('icsLink-web', this)">Copy</button>
          </div>
          <ol start="6">
            <li>Give it a name (e.g. <em>Covey Fellows Events</em>) and click <strong>Import</strong>.</li>
          </ol>
          <div class="note-box">
            📌 <strong>Events not showing up?</strong> Outlook on the web can take up to 24 hours for the first sync. To force it immediately: right-click the subscribed calendar in the left sidebar and choose <strong>Sync</strong>. If no Sync option appears, try removing and re-adding the calendar.
          </div>
        </div>
        <div class="tab-panel" id="tab-desktop">
          <ol>
            <li>Open <strong>Outlook</strong> and click the <strong>Calendar</strong> view (bottom-left).</li>
            <li>In the top ribbon, click <strong>File → Account Settings → Account Settings…</strong></li>
            <li>Click the <strong>Internet Calendars</strong> tab.</li>
            <li>Click <strong>New…</strong> and paste the link below:</li>
          </ol>
          <div class="url-box">
            <code id="icsLink-desktop">https://calendar.google.com/calendar/ical/52e8e3ab637b4bd9cbd0441181013e401bfb62428555e949e059879578b5cdb7%40group.calendar.google.com/public/basic.ics</code>
            <button class="copy-btn" onclick="copyLink('icsLink-desktop', this)">Copy</button>
          </div>
          <ol start="5">
            <li>Click <strong>Add</strong>, give the calendar a name, and click <strong>OK</strong>.</li>
            <li>Click <strong>Close</strong>. The calendar appears under <em>Other Calendars</em>.</li>
          </ol>
          <div class="note-box">
            📌 <strong>Events not showing up?</strong> Click the <strong>Send / Receive</strong> tab in the ribbon → <strong>Send/Receive All Folders</strong> (or press <strong>F9</strong>) to force an immediate sync. If you don't see the <strong>Internet Calendars</strong> tab, use <strong>Outlook on the Web</strong> instead.
          </div>
        </div>
        <div class="tab-panel" id="tab-new">
          <ol>
            <li>Open the new <strong>Outlook</strong> app (Windows 11 / updated Microsoft 365).</li>
            <li>Click <strong>Calendar</strong> in the left sidebar.</li>
            <li>Click <strong>Add calendar</strong> in the top toolbar.</li>
            <li>Select <strong>"Subscribe from web"</strong> from the left menu.</li>
            <li>Paste the link below into the URL field:</li>
          </ol>
          <div class="url-box">
            <code id="icsLink-new">https://calendar.google.com/calendar/ical/52e8e3ab637b4bd9cbd0441181013e401bfb62428555e949e059879578b5cdb7%40group.calendar.google.com/public/basic.ics</code>
            <button class="copy-btn" onclick="copyLink('icsLink-new', this)">Copy</button>
          </div>
          <ol start="6">
            <li>Enter a calendar name and click <strong>Import</strong>.</li>
          </ol>
          <div class="note-box">
            📌 <strong>Events not showing up?</strong> Right-click the calendar in the sidebar and choose <strong>Sync</strong>. — Not sure which version you have? If Outlook shows a <em>"Try the new Outlook"</em> toggle in the top-right, use the <strong>Outlook Desktop (365)</strong> tab instead.
          </div>
        </div>
      </div>
    </div>

    <footer>The Stephen R. Covey Leadership Center &nbsp;·&nbsp; Utah State University</footer>
  </div>

  <script>
    function togglePanel(id) {
      const wrap = document.getElementById(id);
      wrap.classList.toggle('open');
    }

    function copyLink(elementId, btn) {
      const text = document.getElementById(elementId).innerText.trim();
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = '✓ Copied';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
      }).catch(() => {
        const el = document.createElement('textarea');
        el.value = text;
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        btn.textContent = '✓ Copied';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
      });
    }

    function switchTab(btn, tabId) {
      btn.closest('.instructions-panel').querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.closest('.instructions-panel').querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(tabId).classList.add('active');
    }
  </script>

</body>
</html>
